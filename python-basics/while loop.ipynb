   "source": [
    "#start- intialize\n",
    "#stop-condition\n",
    "#step-increment/decrement\n",
    "\n",
    "#wap to print first n natural number take n as user input\n",
    "n=int(input(\"enter any number: \"))\n",
    "i=1\n",
    "while i<n+1:\n",
    "    print(i,end=\" \")\n",
    "    i=i+1\n",
    "print(i)"
   ]
